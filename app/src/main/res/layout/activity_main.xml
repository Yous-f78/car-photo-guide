<?xml version="1.0" encoding="utf-8"?>
<!--
    Main layout (landscape):
      - Left side: camera preview + guide overlay (4:3, fillCenter)
      - Right side: vertical control panel (car-type chips, capture, status)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- ======================== LEFT: CAMERA ======================== -->
    <!-- Camera preview (left side, fills available space) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:scaleType="fillCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/controlPanel"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Guide overlay (same bounds as the preview) -->
    <com.example.carguide.GuideOverlayView
        android:id="@+id/guideOverlay"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="@id/previewView"
        app:layout_constraintEnd_toEndOf="@id/previewView"
        app:layout_constraintTop_toTopOf="@id/previewView"
        app:layout_constraintBottom_toBottomOf="@id/previewView" />

    <!-- ======================== RIGHT: CONTROL PANEL ======================== -->
    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="#E6000000"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/select_type"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:chipSpacingVertical="4dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipCitadine"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_citadine"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipBerline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_berline"
                style="@style/Widget.Material3.Chip.Filter" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSuv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_suv"
                style="@style/Widget.Material3.Chip.Filter" />
        </com.google.android.material.chip.ChipGroup>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCapture"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="20dp"
            android:text="@string/capture"
            android:textSize="16sp"
            android:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart"
            app:backgroundTint="@color/btn_capture" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:text=""
            android:maxWidth="200dp"
            android:maxLines="2"
            android:ellipsize="end" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
